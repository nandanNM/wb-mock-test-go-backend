# Copy to .env and fill in. The app auto-loads .env for local dev; real
# environment variables always take precedence. All values except DATABASE_URL
# have safe defaults.

# --- Server ---
APP_ENV=development          # development | staging | production (production => JSON logs)
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info               # debug | info | warn | error

# Timeouts accept Go durations ("15s", "1m") or bare seconds ("15").
READ_TIMEOUT=10s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s
REQUEST_TIMEOUT=30s          # per-request handler deadline
SHUTDOWN_TIMEOUT=15s

# --- CORS ---
# Comma-separated list of allowed origins, or * for any.
CORS_ALLOWED_ORIGINS=*

# --- Database (PostgreSQL) ---
# REQUIRED. Use your hosted provider's connection string. Hosted providers
# require TLS, so keep sslmode=require.
#
# Neon example:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
# Supabase example:
#   postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Pool tuning (optional).
DB_MAX_CONNS=10
DB_MIN_CONNS=0
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_CONNECT_TIMEOUT=10s
DB_HEALTH_CHECK_PERIOD=1m

# --- Authentication ---
# Access-token signing key: base64 of a 64-byte Ed25519 private key.
# Generate with: make gen-keys   (REQUIRED in production; dev auto-generates an
# ephemeral key + warns — tokens then break on restart).
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_KEY_ID=default
AUTH_JWT_ISSUER=backend
AUTH_JWT_AUDIENCE=backend-api
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=720h

# CSRF signing key (base64). Generate with: make gen-keys
CSRF_HMAC_KEY=

# Cookies: false for local HTTP, true in production (HTTPS required for Secure).
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_DOMAIN=
# How long account-status (ban/suspend/logout) is cached before re-checking the DB.
STATUS_CACHE_TTL=20s

# Google OAuth (OIDC) — enables "Continue with Google".
# Create credentials at https://console.cloud.google.com/apis/credentials and add
# GOOGLE_REDIRECT_URL as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback
# Browser lands here after a successful web login (your SPA URL).
OAUTH_SUCCESS_REDIRECT=
# Grant the 'admin' role to this email on login (seed the first administrator).
AUTH_BOOTSTRAP_ADMIN_EMAIL=
